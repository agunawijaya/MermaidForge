# ============================================================
# mermaidforge — .gitignore
# ============================================================

# --- Rust / Cargo ---
target/
**/target/
*.pdb

# --- Node ---
node_modules/

# --- Python build outputs ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --- PyInstaller scratch (regenerated by build-sidecar.ps1) ---
app/src-tauri/python/build/
app/src-tauri/python/dist/

# --- Sidecar binary (regenerated; ~15 MB build artifact) ---
# Pattern covers Windows (mfengine-x86_64-pc-windows-msvc.exe), Linux
# (mfengine-x86_64-unknown-linux-gnu), macOS (mfengine-x86_64-apple-darwin),
# and any future Tauri sidecar triplets.
app/src-tauri/binaries/mfengine-*

# --- Engine working copies (copied from engines/ by build-sidecar.ps1) ---
app/src-tauri/python/mermaid_to_pptx.py
app/src-tauri/python/mermaid_to_vsdx_generator.py
app/src-tauri/python/template_manual_ref.vsdx

# --- Tauri build outputs ---
# Windows
*.msi
*.exe.config
# Linux (future port)
*.AppImage
*.deb
*.rpm
# macOS (future port)
*.dmg
*.app/

# --- Test corpus regenerable outputs ---
docs/test-corpus/_baseline_pptx/
docs/test-corpus/_trimmed_pptx/

# --- Scratch / prototype directories ---
spike-a/

# --- OS / IDE noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Logs and migration artifacts ---
_*.log
_migration_*.log
*.bak

# --- Personal scratch / local-only files ---
.claude/
CLAUDE.md
Prompt_push_GitHub.md
